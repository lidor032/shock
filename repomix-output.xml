  )
}

function LiveClock() {
  const [time, setTime] = useState(new Date())

  useState(() => {
    const id = setInterval(() => setTime(new Date()), 1000)
    return () => clearInterval(id)
  })

  return (
    <span className="text-green-400 glow font-bold tabular-nums">
      {format(time, 'HH:mm:ss')} UTC
    </span>
  )
}
