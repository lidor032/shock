function closeCard() {
  selEv=null;
  document.getElementById('wm-card').style.display='none';
  updateGlobe();
}

/* ─── VIDEO IDs (populated by loadVideoIds from video_ids.json) ── */
var VIDEO_IDS = {};

function loadVideoIds() {
  fetch('video_ids.json')
    .then(function(r){ return r.ok ? r.json() : null; })
    .then(function(data){ if(data) VIDEO_IDS=data; })
    .catch(function(){});  /* silent — falls back to search link */
}

/* ─── VIDEO MODAL ───────────────────────────────────────── */
function openVideo() {
  if (!selEv) return;
  var ev=selEv, m=TYPE_META[ev.type]||{}, c=m.color||'#00ff41';
  var q=encodeURIComponent(ev.q||ev.title);
  var ytSearch='https://www.youtube.com/results?search_query='+q;
