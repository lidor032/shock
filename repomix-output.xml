}
.glow-amber {
  text-shadow: 0 0 8px var(--amber), 0 0 20px var(--amber);
}
.glow-blue {
  text-shadow: 0 0 8px var(--blue), 0 0 20px var(--blue);
}

/* Border glow */
.border-glow {
  border: 1px solid rgba(0, 255, 65, 0.4);
  box-shadow: 0 0 10px rgba(0, 255, 65, 0.15), inset 0 0 10px rgba(0, 255, 65, 0.05);
}
.border-glow-red {
