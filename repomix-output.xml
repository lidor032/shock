var TL_START = +new Date('2024-01-01');
var TL_END   = +new Date('2026-04-18');

/* ─── STATE ─────────────────────────────────────────────── */
var mode        = 'live';
var selEv       = null;
var curTime     = TL_START;
var isPlaying   = true;
var spd         = 5;
var liveInt     = null;
var rafId       = null;
var lastRts     = null;
var activeEvs   = [];
var globe;

/* ─── GLOBE INIT ────────────────────────────────────────── */
function initGlobe() {
  var el = document.getElementById('wm-globe');
  if (!el) { setTimeout(initGlobe, 50); return; }
  if (typeof Globe === 'undefined') { setTimeout(initGlobe, 100); return; }

  globe = Globe()(el);
  globe
    .globeImageUrl('//unpkg.com/three-globe/example/img/earth-night.jpg')
    .backgroundImageUrl('//unpkg.com/three-globe/example/img/night-sky.png')
    .atmosphereColor('#00cc44')
    .atmosphereAltitude(0.18)
    .width(el.offsetWidth || 800)
    .height(el.offsetHeight || 840);

  setTimeout(function() {
    globe.pointOfView({lat:31, lng:44, altitude:1.3}, 1500);
    /* re-apply correct dimensions after layout settles */
    globe.width(el.offsetWidth || 800).height(el.offsetHeight || 840);
  }, 300);

  buildLegend();
  buildTicker();
  updateClock();
  setInterval(updateClock, 1000);
  loadVideoIds();
  startLive();

  window.addEventListener('resize', function() {
    globe.width(el.offsetWidth).height(el.offsetHeight);
  });
}

/* Works whether the script runs synchronously (iframe/file) or is
   injected into an already-loaded page (Jupyter display(HTML(...))). */
if (typeof Globe !== 'undefined') {
  setTimeout(initGlobe, 0);          /* already loaded — next tick */
} else {
  window.addEventListener('load', initGlobe);   /* wait for CDN script */
  setTimeout(initGlobe, 1500);       /* hard fallback */
}

/* ─── GLOBE UPDATE ──────────────────────────────────────── */
function updateGlobe() {
  /* Two-layer arc system:
     Layer 1 = faint guide path (solid, very dim) — shows the full trajectory
     Layer 2 = bright projectile dot (tiny dash, fast) — the actual "moving missile/drone"
  */
  var arcs = [];
  activeEvs.forEach(function(ev) {
    var baseCol = ev.ac||['#00ff41','#00ff41'];
    var fadeCol = [baseCol[0]+'28', baseCol[1]+'28'];
    (ev.targets||[]).forEach(function(t) {
      /* Guide path — full solid dim line */
      arcs.push({
        sLat:ev.origin.lat, sLng:ev.origin.lng, eLat:t.lat, eLng:t.lng,
        col:fadeCol, alt:ev.aa||0.3,
        dl:1, dg:0, spd:99999, sw:0.4, ev:ev
      });
      /* Projectile dot — tiny bright dash that races along the path */
      arcs.push({
        sLat:ev.origin.lat, sLng:ev.origin.lng, eLat:t.lat, eLng:t.lng,
        col:baseCol, alt:ev.aa||0.3,
        dl:0.03, dg:0.97, spd:ev.as||1800, sw:2.0, ev:ev
      });
    });
  });

  var activeIds = {};
  activeEvs.forEach(function(e){ activeIds[e.id]=true; });

  var pts = [];
  EVENTS.forEach(function(ev) {
    var isAct = activeIds[ev.id];
    var isSel = selEv && selEv.id===ev.id;
    var col   = IMP[ev.imp]||'#00ff41';
    pts.push({lat:ev.origin.lat, lng:ev.origin.lng, label:ev.origin.label,
      sz: isSel?0.6:isAct?0.45:0.2, col:isAct?col:col+'44', alt:0.005, ev:ev});
    if (isAct) {
      (ev.targets||[]).forEach(function(t) {
        pts.push({lat:t.lat, lng:t.lng, label:t.label, sz:0.35, col:'#ff2222', alt:0.005, ev:ev});
      });
    }
  });

  var lbls = activeEvs.map(function(ev) {
    return {lat:ev.origin.lat, lng:ev.origin.lng, text:ev.origin.label, col:TYPE_META[ev.type]&&TYPE_META[ev.type].color||'#00ff41'};
  });

  globe
    .arcsData(arcs)
    .arcStartLat('sLat').arcStartLng('sLng').arcEndLat('eLat').arcEndLng('eLng')
    .arcColor('col').arcAltitude('alt').arcStroke('sw')
    .arcDashLength('dl').arcDashGap('dg').arcDashAnimateTime('spd')
    .onArcClick(function(d){ if(d&&d.ev) showCard(d.ev); })
    .pointsData(pts).pointLat('lat').pointLng('lng')
    .pointColor('col').pointRadius('sz').pointAltitude('alt')
    .onPointClick(function(d){ if(d&&d.ev) showCard(d.ev); })
    .htmlElementsData(lbls).htmlLat('lat').htmlLng('lng').htmlAltitude(0.015)
    .htmlElement(function(d){
      var el=document.createElement('div');
      el.className='ev-label';
      el.textContent=d.text;
      el.style.color=d.col;
      el.style.borderColor=d.col+'88';
      el.style.textShadow='0 0 6px '+d.col;
      return el;
    });

  var n = activeEvs.length;
  document.getElementById('arc-count').textContent = n+' event'+(n!==1?'s':'')+' active';
  document.getElementById('ops-count').textContent = n;
}

/* ─── LIVE MODE ─────────────────────────────────────────── */
function startLive() {
  stopAll();
  activeEvs = pickRandom(3);
  updateGlobe();
  liveInt = setInterval(function(){
    var prevIds = {};
    activeEvs.forEach(function(e){ prevIds[e.id]=true; });
    var pool = EVENTS.filter(function(e){ return !prevIds[e.id]; });
    var next = pool.length ? pool[Math.floor(Math.random()*pool.length)] : EVENTS[Math.floor(Math.random()*EVENTS.length)];
    activeEvs = activeEvs.slice(-2).concat([next]);
    updateGlobe();
  }, 3500);
}

function pickRandom(n) {
  return EVENTS.slice().sort(function(){ return Math.random()-0.5; }).slice(0,n);
}

/* ─── TIMELINE MODE ─────────────────────────────────────── */
var MS_PER_REAL = 86400;
var WIN = 12*3600*1000;

function startTimeline() {
  stopAll();
  buildDots();
  syncTimelineUI();
  if (isPlaying) runTimeline();
}

function runTimeline() {
  lastRts = null;
  rafId = requestAnimationFrame(function tick(ts) {
    if (lastRts!==null) {
      var delta = ts-lastRts;
      curTime = Math.min(curTime+delta*MS_PER_REAL*spd, TL_END);
      if (curTime>=TL_END) curTime=TL_START;
    }
    lastRts=ts;
    activeEvs = EVENTS.filter(function(e){ return e.ts<=curTime && e.ts>=curTime-WIN; });
    updateGlobe();
    syncTimelineUI();
    if (isPlaying) rafId=requestAnimationFrame(tick);
  });
}

function syncTimelineUI() {
  var pct = (curTime-TL_START)/(TL_END-TL_START);
  document.getElementById('tl-range').value = Math.round(pct*1000);
  var d = new Date(curTime);
  var MN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  document.getElementById('tl-date').textContent =
    String(d.getUTCDate()).padStart(2,'0')+' '+MN[d.getUTCMonth()]+' '+d.getUTCFullYear();
  document.querySelectorAll('.tl-dot').forEach(function(dot){
    var ets=parseInt(dot.dataset.ts);
    var act=ets<=curTime&&ets>=curTime-WIN;
    dot.style.opacity=act?'1':'0.3';
    dot.style.transform=act?'translateX(-50%) scale(1.5)':'translateX(-50%)';
  });
}

function buildDots() {
  var cont = document.getElementById('wm-tl-dots');
  cont.innerHTML='';
  var total=TL_END-TL_START;
  EVENTS.forEach(function(ev){
    var pct=((ev.ts-TL_START)/total)*100;
    var btn=document.createElement('button');
    btn.className='tl-dot btn';
    btn.dataset.ts=ev.ts;
    btn.title=ev.title;
    btn.style.cssText='position:absolute;left:'+pct+'%;bottom:0;transform:translateX(-50%);padding:0;opacity:0.3;transition:all 0.3s;cursor:pointer;background:none;border:none';
    var color=IMP[ev.imp]||'#00ff41';
    var sz=ev.imp==='critical'?8:5;
    btn.innerHTML='<span style="display:block;width:'+sz+'px;height:'+sz+'px;border-radius:50%;background:'+color+';box-shadow:0 0 4px '+color+'"></span>';
    btn.addEventListener('click',function(){ curTime=ev.ts; showCard(ev); syncTimelineUI(); });
    cont.appendChild(btn);
  });
}

/* ─── MODE SWITCH ───────────────────────────────────────── */
function setMode(m) {
  mode=m;
  selEv=null;
  document.getElementById('wm-card').style.display='none';
  var bl=document.getElementById('btn-live'), bt=document.getElementById('btn-tl');
  var tp=document.getElementById('wm-tl'),    li=document.getElementById('wm-live-info');
  if (m==='live') {
    bl.className='mbtn al'; bt.className='mbtn';
    tp.style.display='none'; li.style.display='block';
    startLive();
  } else {
    bl.className='mbtn'; bt.className='mbtn at';
    tp.style.display='block'; li.style.display='none';
    startTimeline();
  }
}

function stopAll() {
  if (liveInt){ clearInterval(liveInt); liveInt=null; }
  if (rafId){ cancelAnimationFrame(rafId); rafId=null; }
}

function togglePlay() {
  isPlaying=!isPlaying;
  document.getElementById('tl-playbtn').innerHTML=isPlaying?'&#9646;&#9646;':'&#9654;';
  if (isPlaying){ lastRts=null; runTimeline(); }
  else if(rafId){ cancelAnimationFrame(rafId); rafId=null; }
}

function onScrub(val) {
  curTime=TL_START+(val/1000)*(TL_END-TL_START);
  activeEvs=EVENTS.filter(function(e){ return e.ts<=curTime&&e.ts>=curTime-WIN; });
  updateGlobe(); syncTimelineUI();
}

function setSpeed(s) {
  spd=s;
  document.querySelectorAll('.speed-btn').forEach(function(b){
    b.classList.toggle('act', parseInt(b.textContent)===s);
  });
}

/* ─── EVENT CARD ────────────────────────────────────────── */
function showCard(ev) {
  selEv=ev;
  var card=document.getElementById('wm-card');
  var m=TYPE_META[ev.type]||{};
  var c=m.color||'#00ff41';
  var ic=IMP[ev.imp]||'#00ff41';
  var cc=CC[ev.country]||'#888';
  var tags=(ev.tags||[]).map(function(t){ return '<span style="font-size:10px;padding:2px 6px;border-radius:3px;background:rgba(0,40,0,0.8);color:#336633;border:1px solid #1a3d1a;display:inline-block;margin:1px">'+t+'</span>'; }).join('');
  var tgts=(ev.targets||[]).map(function(t){ return '<div style="font-size:11px;color:#66cc88;margin-left:6px">&#8627; '+t.label+'</div>'; }).join('');
  card.style.cssText='position:absolute;right:16px;top:110px;width:300px;z-index:30;display:flex;flex-direction:column;border-radius:6px;overflow:hidden;max-height:calc(100% - 210px);background:rgba(0,8,0,0.95);border:1px solid '+c+'44;box-shadow:0 0 20px '+c+'11;animation:fadeIn 0.3s ease';
  card.innerHTML='<div style="padding:10px 12px;border-bottom:1px solid '+c+'22;display:flex;gap:8px;align-items:flex-start">'
    +'<div style="flex:1;min-width:0">'
    +'<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap">'
    +(ev.imp==='critical'?'<span style="font-size:9px;font-weight:bold;padding:2px 6px;border-radius:3px;background:'+ic+'22;color:'+ic+';border:1px solid '+ic+'44">&#9685; CRITICAL</span>':'')
    +(ev.sim?'<span style="font-size:9px;font-weight:bold;padding:2px 6px;border-radius:3px;background:rgba(80,60,0,0.5);color:#cc9900;border:1px solid #665500">PROJECTED</span>':'')
    +'</div>'
    +'<div style="font-size:11px;font-weight:bold;color:'+c+';text-shadow:0 0 6px '+c+';line-height:1.3">'+ev.title+'</div>'
    +'<div style="font-size:11px;color:#66cc88;margin-top:2px;line-height:1.3">'+ev.sub+'</div>'
    +'</div>'
    +'<button onclick="closeCard()" style="cursor:pointer;background:none;border:none;color:#336633;font-size:20px;line-height:1;flex-shrink:0">&#215;</button>'
    +'</div>'
    +'<div style="flex:1;overflow-y:auto;padding:12px">'
    +'<div style="display:flex;gap:12px;margin-bottom:10px;flex-wrap:wrap">'
    +'<div><div style="font-size:9px;color:#336633;letter-spacing:2px">DATE</div><div style="font-size:11px;font-weight:bold;color:#00ff41">'+ev.date+'</div></div>'
    +'<div><div style="font-size:9px;color:#336633;letter-spacing:2px">ACTOR</div><div style="font-size:11px;font-weight:bold;color:'+cc+'">'+ev.country+'</div></div>'
    +'<div><div style="font-size:9px;color:#336633;letter-spacing:2px">TYPE</div><div style="font-size:11px;font-weight:bold;color:#00ff41">'+ev.type.toUpperCase()+'</div></div>'
    +'</div>'
    +'<div style="font-size:11px;color:#99ccaa;line-height:1.6;margin-bottom:10px">'+ev.desc+'</div>'
    +'<div style="margin-bottom:8px">'
    +'<div style="font-size:9px;color:#336633;letter-spacing:2px">ORIGIN</div>'
    +'<div style="font-size:11px;color:#66cc88;margin-left:6px">'+(ev.origin&&ev.origin.label||'')+'</div>'
    +'<div style="font-size:9px;color:#336633;letter-spacing:2px;margin-top:4px">TARGETS</div>'
    +tgts+'</div>'
    +(ev.cas?'<div style="margin-bottom:8px"><div style="font-size:9px;color:#336633;letter-spacing:2px">CASUALTIES</div><div style="font-size:11px;margin-left:6px;color:'+(ev.cas.indexOf('killed')>-1||ev.cas.indexOf('KIA')>-1?'#ff9999':'#00ff88')+'">'+ev.cas+'</div></div>':'')
    +'<div style="margin-bottom:8px">'+tags+'</div>'
    +'<div style="font-size:10px;color:#336633">SOURCE: <span style="color:#557755">'+ev.src+'</span></div>'
    +'</div>'
    +'<div style="padding:10px 12px;border-top:1px solid '+c+'22">'
    +'<button onclick="openVideo()" style="width:100%;padding:8px;border-radius:4px;cursor:pointer;font-family:\'Courier New\',monospace;font-size:11px;font-weight:bold;letter-spacing:2px;background:'+c+'22;border:1px solid '+c+'55;color:'+c+';text-shadow:0 0 6px '+c+'">&#9654; WATCH VIDEO FOOTAGE</button>'
    +'</div>';
  updateGlobe();
}

function closeCard() {
  selEv=null;
  document.getElementById('wm-card').style.display='none';
  updateGlobe();
}

/* ─── VIDEO IDs (populated by loadVideoIds from video_ids.json) ── */
var VIDEO_IDS = {};

function loadVideoIds() {
  fetch('video_ids.json')
    .then(function(r){ return r.ok ? r.json() : null; })
    .then(function(data){ if(data) VIDEO_IDS=data; })
    .catch(function(){});  /* silent — falls back to search link */
}

/* ─── VIDEO MODAL ───────────────────────────────────────── */
function openVideo() {
  if (!selEv) return;
  var ev=selEv, m=TYPE_META[ev.type]||{}, c=m.color||'#00ff41';
  var q=encodeURIComponent(ev.q||ev.title);
  var ytSearch='https://www.youtube.com/results?search_query='+q;
  var ytId=VIDEO_IDS[String(ev.id)];

  var inner=document.getElementById('wm-modal-inner');
  inner.style.cssText='border:1px solid '+c+'55;box-shadow:0 0 40px '+c+'22;border-radius:8px;overflow:hidden;display:flex;flex-direction:column;width:min(900px,96%);max-height:92%;background:rgba(0,8,0,0.97)';

  /* Header */
  var html='<div style="padding:12px 16px;display:flex;align-items:flex-start;justify-content:space-between;border-bottom:1px solid '+c+'22;flex-shrink:0">'
    +'<div><div style="font-size:9px;color:#336633;letter-spacing:3px">VIDEO INTELLIGENCE</div>'
    +'<div style="font-size:13px;font-weight:bold;color:'+c+';text-shadow:0 0 8px '+c+'">'+ev.title+'</div>'
    +'<div style="font-size:11px;color:#66cc88">'+ev.sub+'</div></div>'
    +'<button onclick="closeVideo()" style="cursor:pointer;background:none;border:none;color:#336633;font-size:28px;line-height:1;flex-shrink:0;margin-left:16px">&#215;</button>'
    +'</div>';

  if (ytId) {
    /* ── Embedded player when real video ID is known ── */
    html+='<div style="flex:1;background:#000;position:relative;min-height:400px">'
      +'<iframe src="https://www.youtube-nocookie.com/embed/'+ytId+'?autoplay=1&rel=0&modestbranding=1" '
      +'style="position:absolute;inset:0;width:100%;height:100%;border:none" '
      +'allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" '
      +'allowfullscreen></iframe>'
      +'</div>';
  } else {
    /* ── Search fallback when no ID available ── */
    html+='<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px;gap:20px;background:rgba(0,6,0,0.6)">'
      +'<div style="font-size:52px;opacity:0.5">&#127909;</div>'
      +'<div style="text-align:center">'
      +'<div style="font-size:14px;color:#99ccaa;margin-bottom:8px;letter-spacing:1px">Video coverage available on YouTube</div>'
      +'<div style="font-size:12px;color:#557755;font-style:italic">&ldquo;'+ev.title+' '+ev.date+'&rdquo;</div>'
      +'<div style="font-size:11px;color:#1a3d1a;margin-top:8px">Run the YouTube scraper cell in the notebook to enable embedded video</div>'
      +'</div>'
      +'<a href="'+ytSearch+'" target="_blank" rel="noopener" '
      +'style="display:inline-flex;align-items:center;gap:12px;padding:14px 28px;border-radius:6px;text-decoration:none;'
      +'background:'+c+'22;border:1px solid '+c+'66;color:'+c+';font-size:13px;font-weight:bold;font-family:\'Courier New\',monospace;'
      +'letter-spacing:2px;text-shadow:0 0 8px '+c+';box-shadow:0 0 20px '+c+'22">'
      +'&#128269;&nbsp; SEARCH ON YOUTUBE</a>'
      +'</div>';
  }

  html+='<div style="padding:8px 16px;display:flex;align-items:center;justify-content:space-between;font-size:10px;color:#336633;border-top:1px solid '+c+'11;flex-shrink:0">'
    +'<span>SOURCE: '+ev.src+'</span>'
    +'<a href="'+ytSearch+'" target="_blank" rel="noopener" style="color:#336633;text-decoration:underline">YouTube &#8599;</a>'
    +(ev.sim?'<span style="color:#cc9900;font-weight:bold">&#9888; PROJECTED</span>':'<span>'+ev.date+'</span>')
    +'</div>';

  inner.innerHTML=html;
  document.getElementById('wm-modal').style.display='flex';
}

function closeVideo() {
  document.getElementById('wm-modal').style.display='none';
  document.getElementById('wm-modal-inner').innerHTML='';
}

/* ─── FULLSCREEN ────────────────────────────────────────── */
function toggleFullscreen() {
  var container = document.getElementById('wm');
  if (!document.fullscreenElement) {
    (container.requestFullscreen || container.webkitRequestFullscreen || container.mozRequestFullScreen).call(container)
      .catch(function(e){ console.log('Fullscreen error:', e); });
  } else {
    (document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen).call(document);
  }
}

document.addEventListener('fullscreenchange', function() {
  var btn = document.getElementById('fs-btn');
  if (!btn) return;
  if (document.fullscreenElement) {
    btn.innerHTML='&#9974; EXIT';
    btn.title='Exit Fullscreen (Esc)';
  } else {
    btn.innerHTML='&#9974; FULL';
    btn.title='Fullscreen (F)';
  }
  /* Resize globe to fill the new dimensions */
  setTimeout(function(){
    var el=document.getElementById('wm-globe');
    if (globe && el) globe.width(el.offsetWidth).height(el.offsetHeight);
  }, 200);
});
document.addEventListener('webkitfullscreenchange', function() {
  document.dispatchEvent(new Event('fullscreenchange'));
});

/* ─── VIEW PRESETS ──────────────────────────────────────── */
function flyTo(lat, lng, alt) {
  if (globe) globe.pointOfView({lat:lat, lng:lng, altitude:alt}, 1000);
}

/* ─── KEYBOARD SHORTCUTS ────────────────────────────────── */
document.addEventListener('keydown', function(e){
  if (e.key==='Escape') closeVideo();
  if (e.key==='f' || e.key==='F') toggleFullscreen();
});

/* ─── LEGEND ────────────────────────────────────────────── */
function buildLegend() {
  var el=document.getElementById('wm-ltypes');
  Object.keys(TYPE_META).forEach(function(t) {
    var m=TYPE_META[t];
    var row=document.createElement('div');
    row.style.cssText='display:flex;align-items:center;gap:8px;margin-bottom:4px';
    row.innerHTML='<svg width="28" height="10" viewBox="0 0 28 10"><path d="M 2 8 Q 14 0 26 8" stroke="'+m.color+'" stroke-width="2" fill="none" stroke-dasharray="4 2"/></svg>'
      +'<span style="font-size:10px;color:#66cc88">'+m.label+'</span>';
    el.appendChild(row);
  });
}

/* ─── NEWS TICKER ───────────────────────────────────────── */
function buildTicker() {
  var headlines=[
    '[Reuters] Israel signals readiness for further strikes if nuclear talks fail',
    '[AP] Iran enriches uranium to 84% purity — IAEA gravely concerned',
    '[Defense News] US deploys additional THAAD battery to Israel',
    "[Lloyd's List] Houthi attack damages Singapore-flagged tanker in Red Sea",
    '[Times of Israel] Netanyahu: military option against Iran remains on table',
    '[WSJ] US-Iran Oman talks stall over enrichment caps — White House',
    '[IDF] 300+ rockets fired from Gaza since ceasefire collapsed',
    '[NYT] Russia reportedly shares satellite intel with Iran — US officials',
    '[Bloomberg] Saudi Arabia warns regional war could spike oil to $200/barrel',
    '[Tasnim] IRGC test-fires Fatah-2 hypersonic in Persian Gulf exercise',
    '[BBC] UK joins US in Red Sea escort operations amid record Houthi attacks',
    '[Haaretz] Israel air force conducts largest-ever exercise simulating Iran strikes',
    '[Reuters] Hezbollah fires 80 rockets toward Galilee — IDF intercepts majority',
    '[FT] Oil surges 4% as market prices in potential Strait of Hormuz closure',
    '[Pentagon] USS Carl Vinson combat-ready in Persian Gulf as Iran tensions rise'
  ];
  var doubled=headlines.concat(headlines);
  document.getElementById('wm-ttrack').textContent=doubled.map(function(h){ return h+'     \u25c6     '; }).join('');
}

/* ─── CLOCK ─────────────────────────────────────────────── */
function updateClock() {
  var now=new Date();
  var MN=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  document.getElementById('wm-date').textContent=String(now.getUTCDate()).padStart(2,'0')+' '+MN[now.getUTCMonth()]+' '+now.getUTCFullYear();
  document.getElementById('wm-clock').textContent=String(now.getUTCHours()).padStart(2,'0')+':'+String(now.getUTCMinutes()).padStart(2,'0')+':'+String(now.getUTCSeconds()).padStart(2,'0')+' UTC';
}
</script>
