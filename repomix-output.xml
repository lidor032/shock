#wm-card { position:absolute; right:16px; top:110px; width:300px; z-index:30; display:none; border-radius:6px; overflow:hidden; max-height:calc(100% - 210px); display:none; flex-direction:column; background:rgba(0,8,0,0.95) }
#wm-modal { position:absolute; inset:0; z-index:50; display:none; align-items:center; justify-content:center; background:rgba(0,0,0,0.85); backdrop-filter:blur(4px) }
#wm-modal-inner { border-radius:8px; overflow:hidden; display:flex; flex-direction:column; width:min(860px,96%); max-height:90%; background:rgba(0,8,0,0.97) }
#wm-legend { position:absolute; bottom:84px; right:16px; z-index:30; border-radius:6px; padding:12px; min-width:170px }
#wm-tl { position:absolute; bottom:0; left:0; right:0; z-index:30; display:none; border-top:1px solid rgba(0,255,65,0.2) }
#wm-tl-dots { position:relative; height:22px; margin:8px 16px 2px }
#tl-range { width:100%; -webkit-appearance:none; appearance:none; height:4px; background:rgba(0,255,65,0.2); border-radius:2px; outline:none }
#tl-range::-webkit-slider-thumb { -webkit-appearance:none; width:14px; height:14px; border-radius:50%; background:#00ff41; cursor:pointer; box-shadow:0 0 6px #00ff41 }
#wm-live-info { position:absolute; bottom:16px; left:50%; transform:translateX(-50%); z-index:30; padding:8px 24px; text-align:center; border-radius:6px }
#wm-globe { position:absolute; inset:0 }
.ev-label { padding:2px 6px; background:rgba(0,0,0,0.85); font-size:10px; font-family:'Courier New',monospace; pointer-events:none; white-space:nowrap; border:1px solid rgba(0,255,65,0.4) }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.ldot { animation:blink 1s infinite }
.speed-btn { padding:2px 8px; font-size:10px; border-radius:3px; border:1px solid #1a3d1a; color:#336633; cursor:pointer; background:none; font-family:inherit; transition:all 0.2s }
.speed-btn.act { border-color:#00ff41; color:#00ff41; background:rgba(0,255,65,0.1) }
::-webkit-scrollbar { width:4px }
::-webkit-scrollbar-track { background:#000 }
::-webkit-scrollbar-thumb { background:rgba(0,255,65,0.4) }
#fs-btn { padding:5px 10px; font-size:10px; font-weight:bold; letter-spacing:2px; border-radius:3px; cursor:pointer; font-family:'Courier New',monospace; background:rgba(0,20,0,0.8); border:1px solid rgba(0,255,65,0.3); color:#336633; transition:all 0.2s }
#fs-btn:hover { color:#00ff41; border-color:rgba(0,255,65,0.6) }
#wm-views { position:absolute; left:12px; top:50%; transform:translateY(-50%); z-index:30; display:flex; flex-direction:column; gap:3px }
.vbtn-label { font-size:8px; color:#1a3d1a; letter-spacing:3px; text-align:center; padding:4px 0 2px; pointer-events:none }
.vbtn { padding:5px 10px; font-size:9px; font-weight:bold; letter-spacing:2px; border-radius:3px; cursor:pointer; font-family:'Courier New',monospace; background:rgba(0,12,0,0.85); border:1px solid rgba(0,255,65,0.2); color:#336633; transition:all 0.2s; white-space:nowrap; text-align:center; display:block; width:100% }
.vbtn:hover { color:#00ff41; border-color:rgba(0,255,65,0.5); background:rgba(0,30,0,0.9) }
</style>
</head>
<body>
<div id="wm">
  <div id="wm-globe"></div>

  <!-- HEADER -->
  <div id="wm-hdr" class="mp">
    <div id="wm-hdr-l" class="mp">
      <div>
        <div style="font-size:9px;color:#336633;letter-spacing:3px">OSINT THEATER MAP</div>
        <div style="font-size:13px;font-weight:bold;letter-spacing:2px" class="glow">IL / IR / US CONFLICT</div>
      </div>
      <div style="border-left:1px solid #1a3d1a;padding-left:12px;font-size:11px">
        <div style="color:#336633" id="wm-date">-- --- ----</div>
        <div style="font-weight:bold" class="glow" id="wm-clock">--:--:-- UTC</div>
      </div>
    </div>
    <div id="wm-hdr-c">
      <div class="mp" style="display:flex;border-radius:4px;overflow:hidden">
        <button id="btn-live" class="mbtn al" onclick="setMode('live')">
          <span class="ldot" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ff4444;margin-right:6px;vertical-align:middle"></span>LIVE
        </button>
        <button id="btn-tl" class="mbtn" onclick="setMode('timeline')">&#9201; TIMELINE</button>
      </div>
    </div>
    <div id="wm-hdr-r" class="mp">
      <div style="text-align:center">
        <div style="font-size:9px;color:#336633;letter-spacing:2px">IRAN THREAT</div>
        <div style="font-size:12px;font-weight:bold" class="glow-r">CRITICAL</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:9px;color:#336633;letter-spacing:2px">ACTIVE OPS</div>
        <div style="font-size:12px;font-weight:bold" class="glow-a" id="ops-count">3</div>
      </div>
      <div style="text-align:center">
        <div style="font-size:9px;color:#336633;letter-spacing:2px">US CARRIERS</div>
        <div style="font-size:12px;font-weight:bold" class="glow-b">2</div>
      </div>
      <div style="border-left:1px solid #1a3d1a;padding-left:12px">
        <button id="fs-btn" onclick="toggleFullscreen()" title="Fullscreen (F)">&#9974; FULL</button>
      </div>
    </div>
  </div>

  <!-- NEWS TICKER -->
  <div id="wm-ticker">
    <div id="wm-tlabel">
      <span class="ldot" style="width:8px;height:8px;border-radius:50%;background:#ff4444;display:inline-block"></span>
      LIVE NEWS
    </div>
    <div style="flex:1;overflow:hidden;padding-left:12px">
      <span id="wm-ttrack"></span>
    </div>
  </div>

  <!-- EVENT CARD (populated by JS) -->
  <div id="wm-card"></div>

  <!-- VIDEO MODAL -->
  <div id="wm-modal" onclick="if(event.target===this)closeVideo()">
    <div id="wm-modal-inner"></div>
  </div>

  <!-- LEGEND -->
  <div id="wm-legend" class="mp">
    <div style="font-size:10px;letter-spacing:3px;font-weight:bold;margin-bottom:8px" class="glow">LEGEND</div>
    <div style="font-size:9px;color:#336633;letter-spacing:2px;margin-bottom:4px">STRIKE TYPE</div>
    <div id="wm-ltypes"></div>
    <div style="border-top:1px solid #1a3d1a;margin:8px 0"></div>
    <div style="font-size:10px;color:#cc9900">&#128374; Projected scenarios marked</div>
  </div>

  <!-- TIMELINE PANEL -->
  <div id="wm-tl" class="mp">
    <div id="wm-tl-dots"></div>
    <div style="padding:0 16px"><input type="range" id="tl-range" min="0" max="1000" value="0" oninput="onScrub(this.value)"></div>
    <div style="padding:6px 16px 12px;display:flex;align-items:center;gap:12px">
      <button class="btn" id="tl-playbtn" onclick="togglePlay()" style="color:#00ff41;font-size:16px;width:28px;height:28px;display:flex;align-items:center;justify-content:center;border:1px solid #1a3d1a;border-radius:4px">&#9654;</button>
      <div style="display:flex;gap:4px">
        <button class="speed-btn" onclick="setSpeed(1)">1x</button>
        <button class="speed-btn act" onclick="setSpeed(5)">5x</button>
        <button class="speed-btn" onclick="setSpeed(20)">20x</button>
        <button class="speed-btn" onclick="setSpeed(100)">100x</button>
      </div>
      <div style="flex:1;text-align:center">
        <span style="font-size:13px;font-weight:bold" class="glow" id="tl-date">01 Jan 2024</span>
      </div>
      <div style="font-size:10px;color:#336633">Jan 2024 &#8212; Apr 2026</div>
    </div>
  </div>

  <!-- LIVE INFO -->
  <div id="wm-live-info" class="mp">
    <div style="font-size:9px;color:#336633;letter-spacing:2px">ACTIVE OPERATIONS</div>
    <div style="font-size:12px;font-weight:bold" class="glow" id="arc-count">3 arcs tracked</div>
    <div style="font-size:10px;color:#336633;margin-top:2px">Click any arc or marker for details</div>
  </div>

  <!-- CORNER NOTE -->
  <div style="position:absolute;bottom:88px;left:16px;z-index:20;color:#1a3d1a;font-size:10px;pointer-events:none;line-height:1.6">
    <div>&#9672; DATA: OSINT / PUBLIC REPORTING</div>
    <div>&#9672; SIMULATED EVENTS MARKED &#9672;</div>
  </div>

  <!-- VIEW PRESET CONTROLS -->
  <div id="wm-views" class="mp" style="padding:8px 6px">
    <div class="vbtn-label">VIEW</div>
    <button class="vbtn" onclick="flyTo(31,44,1.3)">&#127760; THEATER</button>
    <button class="vbtn" onclick="flyTo(31.5,35.0,0.55)">&#127988; ISRAEL</button>
    <button class="vbtn" onclick="flyTo(33.0,51.5,0.7)">&#128308; IRAN</button>
    <button class="vbtn" onclick="flyTo(20,42,0.9)">&#9875; RED SEA</button>
    <button class="vbtn" onclick="flyTo(26,54,0.7)">&#128674; GULF</button>
    <button class="vbtn" onclick="flyTo(30,40,2.5)">&#128065; WIDE</button>
  </div>
</div>

